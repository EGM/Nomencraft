{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns"
    ]
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 80,
    "indentWidth": 4,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": [
      "src/**/*.ts"
    ],
    "exclude": []
  },
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
    "@cross/dir": "jsr:@cross/dir@^1.1.1",
    "@iankulin/logger": "jsr:@iankulin/logger@^1.1.1",
    "@psych/sheet": "jsr:@psych/sheet@^1.0.8",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/semver": "jsr:@std/semver@^1.0.8",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "typedoc": "npm:typedoc@^0.28.18"
  },
  "lint": {
    "include": [
      "src/"
    ],
    "exclude": [],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "ban-untagged-todo"
      ],
      "exclude": [
        "no-unused-vars"
      ]
    }
  },
  "permissions": {
    "default": {
      "env": {
        "allow": [
          "init_cwd",
          "appdata"
        ]
      },
      "sys": {
        "allow": [
          "hostname"
        ]
      },
      "read": true,
      "write": true
    },
    "test": {
      "env": {
        "allow": [
          "appdata"
        ]
      },
      "sys": {
        "allow": [
          "hostname"
        ]
      },
      "read": true,
      "write": true
    }
  },
  "tasks": {
    "run:simple": {
      "command": "deno run -P src/main.ts",
      "description": "Runs main with no commands or options"
    },
    "run:json": {
      "command": "deno run -P src/main.ts --json",
      "description": "Runs main with option to set logger to json format"
    },
    "run:pattern": {
      "command": "deno run -P src/main.ts pattern",
      "description": "Runs pattern command with no options"
    },
    "run:pattern-json": {
      "command": "deno run -P src/main.ts pattern --json",
      "description": "Runs pattern command with option to set logger to json format"
    },
    "check": {
      "command": "deno fmt && deno lint && deno test -P=test",
      "description": "Runs fmt, lint, and tests with the correct permissions set"
    },
    "dlint": "deno doc --lint src/ ",
    "docs": "deno doc --html --output=docs-html src/ "
  },
  "test": {
    "include": [
      "src/"
    ],
    "exclude": [
      "docs/"
    ]
  }
}