{
  // Turn on the Deno language server for this workspace
  "deno.enable": true,
  // Point to your config file (deno.json or deno.jsonc)
  "deno.config": "./deno.json",
  // Use Deno as the formatter
  "editor.defaultFormatter": "denoland.vscode-deno",
  "editor.formatOnSave": true,
  // Enable Deno linting
  "deno.lint": true,
  // Enable Deno test integration (Test Explorer)
  "deno.testing.enable": true,
  // Disable VS Code’s built‑in JS/TS validators
  // (prevents Node/Vitest/TS Server from hijacking files)
  "js/ts.validate.enabled": false,
  // Make import suggestions come from Deno ecosystems
  "deno.suggest.imports.hosts": {
    "https://jsr.io": true
  },
  // Optional: keep formatting consistent across the workspace
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  // Workspace dictionary
  "cSpell.words": [
    "Artis",
    "asynciterable",
    "CBOD",
    "Ferarum",
    "infantilize",
    "Kjeldahl",
    "MLSS",
    "MLVSS",
    "Nomencraft",
    "Orthophosphate",
    "Principia",
    "repr",
    "therapize",
    "Trichloroethane",
    "Validatable",
    "WWTP"
  ],
  "cSpell.ignoreWords": [
    "Futurenomicon",
    "Lumo",
    "Renamer",
    "bursty",
    "dlint",
    "docsmd",
    "iankulin",
    "lfirst",
    "reallyfinal",
    "replayable",
    "stdlib"
  ],
  // TODO Tree settings
  "todoSidebar.activeFile": "./docs/TODO.md",
  "todoSidebar.onDoneAction": "move",
  "todoSidebar.hiddenSections": [
    "Done",
    "Hidden*"
  ],
  "annotation.behavior": {
    "mode": "replace" // keep until cleanup is done
  },
  "annotation.global": {
    "authorInfo": "John LaDuke",
    "versionInfo": "0.0.0-dev",
    "licenseInfo": "MIT",
    "copyrightInfo": "(c) 2026 John LaDuke"
  },
  "annotation.class.tags": {
    "classTag": true,
    "abstractTag": true,
    "extendsTag": true,
    "implementsTag": true,
    "authorTag": true,
    "aliasTag": false,
    "versionTag": true,
    "nameTag": true,
    "descriptionTag": true,
    "seeTag": true,
    "exampleTag": true,
    "templateTag": true
  },
  "annotation.interface.tags": {
    "interfaceTag": true,
    "extendsTag": true,
    "authorTag": true,
    "versionTag": true,
    "templateTag": true,
    "aliasTag": false,
    "nameTag": true,
    "descriptionTag": true,
    "seeTag": false,
    "exampleTag": false
  },
  "annotation.method.tags": {
    "asyncTag": true,
    "functionTag": true,
    "constructorTag": true,
    "throwsTag": true,
    "paramsTag": true,
    "returnsTag": true,
    "staticTag": true,
    "accessTag": true,
    "authorTag": false,
    "aliasTag": false,
    "versionTag": false,
    "nameTag": true,
    "descriptionTag": true,
    "seeTag": false,
    "exampleTag": false,
    "templateTag": true
  },
  "annotation.property.tags": {
    "propertyTag": true,
    "typeTag": false, // TS already knows the type
    "staticTag": true,
    "defaultTag": false,
    "aliasTag": false,
    "nameTag": true,
    "descriptionTag": true,
    "seeTag": false,
    "exampleTag": false,
    "templateTag": false
  },
  "annotation.enum.tags": {
    "enumTag": true,
    "aliasTag": false,
    "nameTag": true,
    "descriptionTag": true,
    "seeTag": false,
    "exampleTag": false
  },
  "annotation.typedef.tags": {
    "typedefTag": false, // kill typedef spam
    "typeTag": false, // kill @type spam
    "templateTag": false,
    "aliasTag": false,
    "nameTag": true,
    "descriptionTag": true,
    "seeTag": false,
    "exampleTag": false
  }
}