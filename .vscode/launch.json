{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "request": "launch",
      "name": "Launch Generate MD Docs",
      "type": "node",
      "program": "${workspaceFolder}/.scripts/gen_md_docs.ts",
      "cwd": "${workspaceFolder}",
      "env": {},
      "runtimeExecutable": "C:\\Users\\John\\.deno\\bin\\deno.EXE",
      "runtimeArgs": [
        "run",
        "--unstable",
        "--config",
        "./deno.json",
        "--inspect-wait",
        "--allow-all"
      ],
      "args": [
        "src",
        "docs-md"
      ],
      "attachSimplePort": 9229
    },
    {
      "request": "launch",
      "name": "Launch Test Docs",
      "type": "node",
      "program": "${workspaceFolder}/src/_meta/DocMd.ts",
      "cwd": "${workspaceFolder}",
      "env": {},
      "runtimeExecutable": "C:\\Users\\John\\.deno\\bin\\deno.EXE",
      "runtimeArgs": [
        "run",
        "--unstable",
        "--config",
        "./deno.json",
        "--inspect-wait",
        "--allow-all"
      ],
      "args": [
        "src/**/*.ts",
        "-o",
        "out_folder",
        "-e",
        "test"
      ],
      "attachSimplePort": 9229
    },
    {
      "request": "launch",
      "name": "Launch Nomencraft",
      "type": "node",
      "program": "${workspaceFolder}/src/main.ts",
      "cwd": "${workspaceFolder}",
      "env": {},
      "runtimeExecutable": "C:\\Users\\John\\.deno\\bin\\deno.EXE",
      "runtimeArgs": [
        "run",
        "--unstable",
        "--config",
        "./deno.json",
        "--inspect-wait",
        // "--allow-all",
        "-P"
      ],
      "args": [
        ".research/products",
        "--log",
        "./log/log.log",
        "--pattern",
        "patterns"
      ],
      "attachSimplePort": 9229
    }
  ]
}