  "version": "0.2.0",
  "configurations": [
    {
      "request": "launch",
      "name": "Launch Generate MD Docs",
      "type": "node",
      "program": "${workspaceFolder}/.scripts/gen_md_docs.ts",
      "cwd": "${workspaceFolder}",
      "env": {},
      "runtimeExecutable": "C:\\Users\\John\\.deno\\bin\\deno.EXE",
      "runtimeArgs": [
        "run",
        "--unstable",
        "--config",
        "./deno.json",
        "--inspect-wait",
        "--allow-all"
      ],
      "args": [
        "src",
        "docs-md"
      ],
      "attachSimplePort": 9229
    }
  ]
}